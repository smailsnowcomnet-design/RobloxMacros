<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="RobloxMacro.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Roblox Macro - Anime Vanguards"
    Width="900"
    Height="700"
    Background="#1E1E1E"
    Foreground="#FFFFFF"
    WindowStartupLocation="CenterScreen"
    ResizeMode="CanResize">

    <Window.Resources>
        <!-- Темный фон -->
        <SolidColorBrush x:Key="DarkBackground" Color="#1E1E1E" />
        <SolidColorBrush x:Key="CardBackground" Color="#2D2D2D" />
        <SolidColorBrush x:Key="AccentBlue" Color="#0078D4" />
        <SolidColorBrush x:Key="AccentGreen" Color="#27AE60" />
        <SolidColorBrush x:Key="AccentRed" Color="#E74C3C" />
        <SolidColorBrush x:Key="AccentOrange" Color="#E67E22" />

        <!-- Стиль кнопки -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBlue}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            BorderThickness="0">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#106EBE" />
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect
                                            BlurRadius="8"
                                            ShadowDepth="2"
                                            Opacity="0.4"
                                            Color="#0078D4" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#005A9E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль кнопки действия (запись) -->
        <Style x:Key="RecordButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentGreen}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#229954" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль кнопки стоп -->
        <Style x:Key="StopButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentRed}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C0392B" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль ComboBox -->
        <Style x:Key="ModernComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource CardBackground}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBlue}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <!-- Стиль TextBox -->
        <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource CardBackground}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBlue}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="IBeam" />
        </Style>

        <!-- Стиль CheckBox -->
        <Style x:Key="ModernCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <!-- Стиль Label -->
        <Style x:Key="ModernLabelStyle" TargetType="Label">
            <Setter Property="Foreground" Value="#E0E0E0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Medium" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource DarkBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ЗАГОЛОВОК -->
        <Border
            Grid.Row="0"
            Background="#252525"
            BorderBrush="#3D3D3D"
            BorderThickness="0,0,0,1"
            Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        Text="🎮"
                        FontSize="28"
                        VerticalAlignment="Center"
                        Margin="0,0,10,0" />
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock
                            Text="Roblox Macro"
                            FontSize="22"
                            FontWeight="Bold"
                            Foreground="#0078D4" />
                        <TextBlock
                            Text="Anime Vanguards Edition"
                            FontSize="12"
                            Foreground="#808080"
                            Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="1" Width="36" Height="36" HorizontalAlignment="Right" VerticalAlignment="Center" Click="OnOpenSettings" ToolTip="Настройки">
                    <TextBlock Text="⚙" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center" />
                </Button>
            </Grid>
        </Border>

        <!-- ОСНОВНОЙ КОНТЕНТ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0">
            <StackPanel Orientation="Vertical" Margin="20">

                <!-- РАЗДЕЛ 1: Выбор режима игры -->
                <Border
                    Background="{StaticResource CardBackground}"
                    CornerRadius="12"
                    Padding="20"
                    Margin="0,0,0,15"
                    BorderBrush="#3D3D3D"
                    BorderThickness="1">
                    <StackPanel Orientation="Vertical">
                        <TextBlock
                            Text="🎯 Выбор режима игры"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="#0078D4"
                            Margin="0,0,0,12" />

                        <!-- Карточки режимов -->
                        <ItemsControl ItemsSource="{Binding GameModes}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button
                                        Command="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=GameModeClickCommand}"
                                        CommandParameter="{Binding Mode}"
                                        Style="{StaticResource ModernButtonStyle}"
                                        Background="{StaticResource CardBackground}"
                                        Foreground="White"
                                        Padding="16,12"
                                        Margin="0,0,10,0"
                                        BorderThickness="2"
                                        BorderBrush="#3D3D3D">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Icon}" FontSize="16" Margin="0,0,8,0" />
                                            <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Выбранный режим -->
                        <Border
                            Background="#1E3A5F"
                            CornerRadius="8"
                            Padding="12,10"
                            Margin="0,12,0,0"
                            BorderBrush="{StaticResource AccentBlue}"
                            BorderThickness="1">
                            <TextBlock
                                Text="{Binding SelectedGameModeName, StringFormat='Выбранный режим: {0}'}"
                                Foreground="#64B5F6"
                                FontSize="12"
                                FontWeight="Medium" />
                        </Border>
                    </StackPanel>
                </Border>

                <!-- РАЗДЕЛ 2: Управление записью и воспроизведением -->
                <Border
                    Background="{StaticResource CardBackground}"
                    CornerRadius="12"
                    Padding="20"
                    Margin="0,0,0,15"
                    BorderBrush="#3D3D3D"
                    BorderThickness="1">
                    <StackPanel Orientation="Vertical">
                        <TextBlock
                            Text="⏺️ Управление макросом"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="#0078D4"
                            Margin="0,0,0,12" />

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Кнопка начать запись -->
                            <Button
                                Grid.Row="0"
                                Grid.Column="0"
                                Content="▶ Начать запись"
                                Style="{StaticResource RecordButtonStyle}"
                                Click="OnStartRecording"
                                IsEnabled="{Binding IsRecording, Converter={StaticResource InvertBoolConverter}}"
                                Margin="0,0,10,10" />

                            <!-- Кнопка остановить запись -->
                            <Button
                                Grid.Row="0"
                                Grid.Column="1"
                                Content="⏹ Стоп запись"
                                Style="{StaticResource StopButtonStyle}"
                                Click="OnStopRecording"
                                IsEnabled="{Binding IsRecording}"
                                Margin="0,0,10,10" />

                            <!-- Кнопка запустить повтор -->
                            <Button
                                Grid.Row="0"
                                Grid.Column="2"
                                Content="▶ Запуск повтора"
                                Style="{StaticResource ModernButtonStyle}"
                                Background="{StaticResource AccentOrange}"
                                Click="OnStartPlayback"
                                IsEnabled="{Binding IsPlaying, Converter={StaticResource InvertBoolConverter}}"
                                Margin="0,0,10,10" />

                            <!-- Кнопка остановить повтор -->
                            <Button
                                Grid.Row="0"
                                Grid.Column="3"
                                Content="⏹ Стоп повтор"
                                Style="{StaticResource StopButtonStyle}"
                                Click="OnStopPlayback"
                                IsEnabled="{Binding IsPlaying}"
                                Margin="0,0,0,10" />

                            <!-- Очистить запись -->
                            <Button
                                Grid.Row="1"
                                Grid.Column="0"
                                Grid.ColumnSpan="4"
                                Content="🧹 Очистить запись"
                                Style="{StaticResource ModernButtonStyle}"
                                Background="#5D6D7E"
                                Click="OnClearRecording"
                                IsEnabled="{Binding IsRecording, Converter={StaticResource InvertBoolConverter}}"
                                Margin="0,0,0,10" />
                        </Grid>

                        <!-- Информация о записи -->
                        <Border
                            Background="#1E3A5F"
                            CornerRadius="8"
                            Padding="12,10"
                            Margin="0,12,0,0"
                            BorderBrush="{StaticResource AccentBlue}"
                            BorderThickness="1">
                            <StackPanel Orientation="Vertical">
                                <TextBlock
                                    Text="{Binding RecordingTimeDisplay, StringFormat='Время записи: {0}'}"
                                    Foreground="#64B5F6"
                                    FontSize="12"
                                    FontWeight="Medium"
                                    Margin="0,0,0,4" />
                                <TextBlock
                                    Text="{Binding RecordedActionsCount, StringFormat='Действий: {0}'}"
                                    Foreground="#64B5F6"
                                    FontSize="12"
                                    FontWeight="Medium" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- РАЗДЕЛ 3: Параметры воспроизведения -->
                <Border
                    Background="{StaticResource CardBackground}"
                    CornerRadius="12"
                    Padding="20"
                    Margin="0,0,0,15"
                    BorderBrush="#3D3D3D"
                    BorderThickness="1">
                    <StackPanel Orientation="Vertical">
                        <TextBlock
                            Text="⚙️ Параметры воспроизведения"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="#0078D4"
                            Margin="0,0,0,12" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Количество повторов -->
                            <Label
                                Grid.Column="0"
                                Grid.Row="0"
                                Content="Повторов:"
                                Style="{StaticResource ModernLabelStyle}"
                                Margin="0,0,10,10" />
                            <TextBox
                                Grid.Column="1"
                                Grid.Row="0"
                                Text="{Binding MacroRepetitions, UpdateSourceTrigger=PropertyChanged}"
                                Style="{StaticResource ModernTextBoxStyle}"
                                IsEnabled="{Binding InfiniteRepeat, Converter={StaticResource InvertBoolConverter}}"
                                Margin="0,0,0,10" />

                            <!-- Бесконечный повтор -->
                            <CheckBox
                                Grid.Column="0"
                                Grid.Row="1"
                                Grid.ColumnSpan="2"
                                Content="♾️ Бесконечный повтор"
                                IsChecked="{Binding InfiniteRepeat, UpdateSourceTrigger=PropertyChanged}"
                                Style="{StaticResource ModernCheckBoxStyle}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- РАЗДЕЛ 4: Дополнительные функции -->
                <Border
                    Background="{StaticResource CardBackground}"
                    CornerRadius="12"
                    Padding="20"
                    Margin="0,0,0,15"
                    BorderBrush="#3D3D3D"
                    BorderThickness="1">
                    <StackPanel Orientation="Vertical">
                        <TextBlock
                            Text="🔧 Дополнительные функции"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="#0078D4"
                            Margin="0,0,0,12" />

                        <Button
                            Content="📷 Настроить камеру Roblox"
                            Style="{StaticResource ModernButtonStyle}"
                            Background="#9B59B6"
                            Click="OnSetupCamera">
                            <Button.Effect>
                                <DropShadowEffect
                                    BlurRadius="6"
                                    ShadowDepth="1"
                                    Opacity="0.3"
                                    Color="#9B59B6" />
                            </Button.Effect>
                        </Button>

                        <CheckBox
                            Content="📌 Поверх других окон"
                            IsChecked="{Binding IsAlwaysOnTop, UpdateSourceTrigger=PropertyChanged}"
                            Style="{StaticResource ModernCheckBoxStyle}"
                            Margin="0,12,0,0" />

                        <TextBlock
                            Text="💡 Совет: Эта функция выравнивает обзор камеры в Roblox и удерживает окно макроса поверх других приложений"
                            FontSize="11"
                            Foreground="#808080"
                            Margin="0,8,0,0"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- РАЗДЕЛ 5: Информация о горячих клавишах -->
                <Border
                    Background="{StaticResource CardBackground}"
                    CornerRadius="12"
                    Padding="20"
                    Margin="0,0,0,0"
                    BorderBrush="#3D3D3D"
                    BorderThickness="1">
                    <StackPanel Orientation="Vertical">
                        <TextBlock
                            Text="⌨️ Глобальные горячие клавиши"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="#0078D4"
                            Margin="0,0,0,12" />

                        <TextBlock
                            Text="F7 — Запустить/остановить повтор макроса"
                            FontSize="12"
                            Foreground="#E0E0E0"
                            Margin="0,0,0,6" />

                        <TextBlock
                            Text="Подсказка: для управления записью используйте F9"
                            FontSize="11"
                            Foreground="#A0A0A0"
                            Margin="0,0,0,6" />

                        <TextBlock
                            Text="F9 — Горячая клавиша записи (нажмите для переключения)"
                            FontSize="12"
                            Foreground="#E0E0E0"
                            Margin="0,0,0,6" />

                        <TextBlock
                            Text="💡 Клавиши работают даже когда приложение свернуто!"
                            FontSize="11"
                            Foreground="#808080"
                            Margin="0,8,0,0"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ИНФОРМАЦИОННАЯ ПАНЕЛЬ (СТАТУС БАР) -->
        <Border
            Grid.Row="2"
            Background="#252525"
            BorderBrush="#3D3D3D"
            BorderThickness="0,1,0,0"
            Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    Text="{Binding StatusMessage, StringFormat='📊 Статус: {0}'}"
                    FontSize="12"
                    Foreground="#E0E0E0"
                    VerticalAlignment="Center" />

                <StackPanel
                    Grid.Column="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">

                    <!-- Индикатор записи -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                        <TextBlock
                            Text="●"
                            FontSize="10"
                            Foreground="{Binding IsRecording, Converter={StaticResource RecordingIndicatorConverter}}"
                            Margin="0,0,4,0" />
                        <TextBlock
                            Text="Запись"
                            FontSize="11"
                            Foreground="#E0E0E0" />
                    </StackPanel>

                    <!-- Индикатор воспроизведения -->
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            Text="●"
                            FontSize="10"
                            Foreground="{Binding IsPlaying, Converter={StaticResource PlayingIndicatorConverter}}"
                            Margin="0,0,4,0" />
                        <TextBlock
                            Text="Воспроизведение"
                            FontSize="11"
                            Foreground="#E0E0E0" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ФУТЕР -->
        <Border
            Grid.Row="3"
            Background="#1A1A1A"
            Padding="20,10"
            BorderBrush="#3D3D3D"
            BorderThickness="0,1,0,0">
            <TextBlock
                Text="© 2026 Roblox Macro Suite | v1.0 | Made with ❤️"
                FontSize="10"
                Foreground="#606060"
                TextAlignment="Center" />
        </Border>

    </Grid>
</Window>
