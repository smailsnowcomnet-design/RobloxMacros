<Window x:Class="RobloxMacro.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки" Height="420" Width="480" WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="⚙️ Настройки приложения" FontSize="16" FontWeight="Bold" />

        <!-- Камера -->
        <GroupBox Header="Положение камеры" Grid.Row="1" Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal" Margin="8">
                <StackPanel Orientation="Vertical" Width="140">
                    <TextBlock Text="Ширина" />
                    <TextBox Text="{Binding CameraWidth, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <StackPanel Orientation="Vertical" Width="140" Margin="8,0,0,0">
                    <TextBlock Text="Высота" />
                    <TextBox Text="{Binding CameraHeight, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <StackPanel Orientation="Vertical" Width="140" Margin="8,0,0,0">
                    <TextBlock Text="Глубина" />
                    <TextBox Text="{Binding CameraDepth, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <!-- Горячие клавиши и сохранение -->
        <GroupBox Header="Горячие клавиши и сохранение" Grid.Row="2" Margin="0,10,0,0">
            <StackPanel Margin="8">
                <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
                    <TextBlock Text="Старт/Стоп (F7 по умолчанию):" VerticalAlignment="Center" Width="220" />
                    <TextBox Width="160" PreviewKeyDown="HotkeyBox_PreviewKeyDown" Tag="Start" Text="{Binding HotkeyStartStopDisplay, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>


                <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
                    <TextBlock Text="Запись (F9 по умолчанию):" VerticalAlignment="Center" Width="220" />
                    <TextBox Width="160" PreviewKeyDown="HotkeyBox_PreviewKeyDown" Tag="Record" Text="{Binding HotkeyRecordDisplay, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
                    <TextBlock Text="Папка для сохранения:" VerticalAlignment="Center" Width="220" />
                    <TextBox x:Name="SavePathBox" Width="260" Text="{Binding SaveFolderPath, UpdateSourceTrigger=PropertyChanged}" PreviewMouseDown="SavePathBox_PreviewMouseDown" LostFocus="SavePathBox_LostFocus" ToolTip="{Binding SaveFolderPath}" />
                    <Button Content="Обзор" Click="BrowseFolder_Click" Margin="6,0,0,0" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                    <Button Content="Сохранить настройки" Click="SaveSettings_Click" Width="150" />
                    <Button Content="Сохранить макрос" Click="SaveMacro_Click" Margin="8,0,0,0" Width="120" />
                    <Button Content="Загрузить макрос" Click="LoadMacro_Click" Margin="8,0,0,0" Width="120" />
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Закрыть" Click="Close_Click" Width="90" />
        </StackPanel>
    </Grid>
</Window>
